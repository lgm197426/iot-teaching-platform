{
  "$schema": "https://openapi.vercel.sh/vercel-platform-model.json",
  "version": 2,
  "name": "iot-teaching-platform",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "out"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
